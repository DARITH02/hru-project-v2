APP_NAME=HRU-ATMS
APP_ENV=production
APP_KEY=
# 🤖 Telegram Notifications
TELEGRAM_BOT_TOKEN=

# Real AI attendance assistant. Keep API keys only on the server.
AI_ASSISTANT_ENABLED=true
AI_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=qwen/qwen3.6-27b
GROQ_BASE_URL=https://api.groq.com/openai/v1

# ☁️ Cloudinary
CLOUDINARY_URL=
CLOUDINARY_UPLOAD_PRESET=

# Google Drive backups.
# Service account mode: use GOOGLE_DRIVE_CREDENTIALS, GOOGLE_DRIVE_CREDENTIALS_BASE64, or GOOGLE_DRIVE_CREDENTIALS_PATH.
# OAuth mode: use GOOGLE_DRIVE_CLIENT_ID, GOOGLE_DRIVE_CLIENT_SECRET, and GOOGLE_DRIVE_REFRESH_TOKEN.
GOOGLE_DRIVE_CREDENTIALS=
GOOGLE_DRIVE_CREDENTIALS_BASE64=
GOOGLE_DRIVE_CREDENTIALS_PATH=
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REFRESH_TOKEN=
GOOGLE_DRIVE_REDIRECT_URI=http://localhost:8080/google-drive/oauth/callback
GOOGLE_DRIVE_FOLDER_ID=


GOOGLE_CLIENT_ID=#970517063724-o0jhtkev1osb7r8spe3ofa7radbpisdg.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=#your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8001/api/auth/google/callback


APP_DEBUG=false
# Local computer only:
APP_URL=http://localhost:8080
FRONTEND_URL=http://localhost:3000

# Phone on same Wi-Fi example:
# APP_URL=http://YOUR_PC_WIFI_IP:8080
# FRONTEND_URL=http://YOUR_PC_WIFI_IP:3000
# STUDENT_QR_PUBLIC_URL=http://YOUR_PC_WIFI_IP:8080
# Docker host port. Use 8080 on Windows/local development; set to 80 on Debian
# servers if port 80 is available and you want the site served without :8080.
APP_HTTP_PORT=8080
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:80,localhost:3000,localhost:3001,localhost:5173,localhost:8080,127.0.0.1,127.0.0.1:80,127.0.0.1:3000,127.0.0.1:3001,127.0.0.1:5173,127.0.0.1:8080,192.168.18.2:3000,192.168.18.2:3001,192.168.18.2:5173,192.168.18.2:8080,192.168.18.10:8080
TEACHER_QR_PUBLIC_URL=
STUDENT_QR_PUBLIC_URL=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
REVERB_APP_ID=hru-ats
REVERB_APP_KEY=hru-ats-key
REVERB_APP_SECRET=hru-ats-secret
REVERB_HOST=127.0.0.1
REVERB_PORT=8091
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8091
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
SUPER_ADMIN_KEY=hru_manager
ALLOW_STUDENT_CODE_LOGIN=false
PUBLIC_REGISTRATION_ENABLED=true
DEMO_LOGIN_ENABLED=true
